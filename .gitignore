# NVIDIA Portfolio Diversification - Git Ignore File
# ==================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# Data files (large datasets)
data/raw/*.csv
data/raw/*.parquet
data/processed/*.csv
data/processed/*.parquet

# Keep directory structure but ignore contents
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/results/*
!data/results/.gitkeep


# Keep example outputs (small files for documentation)
!outputs/figures/example_*.png
!outputs/reports/example_*.csv

# Logs
*.log
logs/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Environment variables
.env
.env.local

# OS
Thumbs.db
.DS_Store

# WGU Submission files (keep these)
!docs/FINAL_REPORT.docx
!docs/FINAL_REPORT.pdf
!PANOPTO_LINK.txt

# misc
inputs.txt
wgu_rubric_coverage.csv
project_summary_table.csv
